#!/usr/bin/env python3
"""
invo-updater — FOTA update client for INVO display
Polls GitHub Releases, verifies RSA-SHA256 signature, installs update.
"""
import os, sys, json, hashlib, shutil, subprocess, tempfile, logging, base64
import urllib.request, urllib.error

# ── config ────────────────────────────────────────────────────────────────────
GITHUB_REPO  = "intellicar/invo-display"           # ← your repo
API_URL      = f"https://api.github.com/repos/{GITHUB_REPO}/releases/latest"
PUBKEY_PATH  = "/etc/invo/update.pub"
VERSION_FILE = "/etc/invo/version"
BACKUP_DIR   = "/etc/invo/backup"

# (extracted_path_inside_tarball, install_destination)
INSTALL_MAP = [
    ("bin/lvglsim",            "/home/intelli/lv_port_linux/build/bin/lvglsim"),
    ("scripts/invo_bridge.py", "/home/intelli/invo_bridge.py"),
]

SERVICES = ["invo-lvgl.service", "invo-bridge.service"]
# ─────────────────────────────────────────────────────────────────────────────

logging.basicConfig(
    level=logging.INFO,
    format="%(asctime)s [invo-updater] %(levelname)s: %(message)s",
    handlers=[logging.StreamHandler()]
)
log = logging.getLogger()


def get_local_version():
    try:
        with open(VERSION_FILE) as f:
            return f.read().strip()
    except FileNotFoundError:
        return "0.0.0"


def fetch_json(url):
    req = urllib.request.Request(url, headers={"User-Agent": "invo-updater/1.0"})
    with urllib.request.urlopen(req, timeout=15) as r:
        return json.loads(r.read())


def download_file(url, dest):
    log.info(f"Downloading {os.path.basename(url)} ...")
    req = urllib.request.Request(url, headers={"User-Agent": "invo-updater/1.0"})
    with urllib.request.urlopen(req, timeout=120) as r, open(dest, 'wb') as f:
        shutil.copyfileobj(r, f)


def sha256_file(path):
    h = hashlib.sha256()
    with open(path, 'rb') as f:
        for chunk in iter(lambda: f.read(65536), b''):
            h.update(chunk)
    return h.hexdigest()


def verify_signature(tarball_path, sig_b64):
    sig_path = tarball_path + ".sig"
    try:
        with open(sig_path, 'wb') as f:
            f.write(base64.b64decode(sig_b64))
        result = subprocess.run(
            ['openssl', 'dgst', '-sha256', '-verify', PUBKEY_PATH,
             '-signature', sig_path, tarball_path],
            capture_output=True, text=True
        )
        return result.returncode == 0
    finally:
        if os.path.exists(sig_path):
            os.remove(sig_path)


def backup_current():
    os.makedirs(BACKUP_DIR, exist_ok=True)
    for _, dst in INSTALL_MAP:
        if os.path.exists(dst):
            shutil.copy2(dst, os.path.join(BACKUP_DIR, os.path.basename(dst)))
    with open(VERSION_FILE) as f:
        ver = f.read().strip()
    with open(os.path.join(BACKUP_DIR, "version"), 'w') as f:
        f.write(ver)
    log.info(f"Backed up current version to {BACKUP_DIR}")


def install_files(tarball_path, new_version):
    with tempfile.TemporaryDirectory() as tmp:
        subprocess.run(['tar', '-xzf', tarball_path, '-C', tmp], check=True)
        for src_rel, dst in INSTALL_MAP:
            src = os.path.join(tmp, src_rel)
            if not os.path.exists(src):
                log.warning(f"{src_rel} not in tarball — skipping")
                continue
            os.makedirs(os.path.dirname(dst), exist_ok=True)
            tmp_dst = dst + ".new"
            shutil.copy2(src, tmp_dst)
            os.chmod(tmp_dst, 0o755)
            os.replace(tmp_dst, dst)
            log.info(f"  installed {src_rel} → {dst}")

    os.makedirs(os.path.dirname(VERSION_FILE), exist_ok=True)
    with open(VERSION_FILE, 'w') as f:
        f.write(new_version)


def restart_services():
    for svc in SERVICES:
        log.info(f"Restarting {svc} ...")
        subprocess.run(['systemctl', 'restart', svc])


def get_asset_url(assets, name):
    for a in assets:
        if a['name'] == name:
            return a['browser_download_url']
    return None


def main():
    local_ver = get_local_version()
    log.info(f"Current version: {local_ver}")

    try:
        release = fetch_json(API_URL)
    except Exception as e:
        log.error(f"Failed to reach GitHub: {e}")
        sys.exit(1)

    remote_ver = release['tag_name'].lstrip('v')
    log.info(f"Latest release:  {remote_ver}")

    if remote_ver <= local_ver:
        log.info("Already up to date.")
        return

    assets = release.get('assets', [])
    manifest_url = get_asset_url(assets, 'manifest.json')
    if not manifest_url:
        log.error("Release has no manifest.json asset — skipping")
        sys.exit(1)

    try:
        manifest = fetch_json(manifest_url)
    except Exception as e:
        log.error(f"Failed to fetch manifest: {e}")
        sys.exit(1)

    tarball_name = manifest['package']
    tarball_url  = get_asset_url(assets, tarball_name)
    if not tarball_url:
        log.error(f"Asset '{tarball_name}' not found in release")
        sys.exit(1)

    with tempfile.TemporaryDirectory() as tmp:
        tarball_path = os.path.join(tmp, tarball_name)

        try:
            download_file(tarball_url, tarball_path)
        except Exception as e:
            log.error(f"Download failed: {e}")
            sys.exit(1)

        got = sha256_file(tarball_path)
        if got != manifest['sha256']:
            log.error(f"SHA256 mismatch — aborting (got {got[:16]}...)")
            sys.exit(1)
        log.info("SHA256 verified ✓")

        if manifest.get('signature', 'UNSIGNED') != 'UNSIGNED':
            if not verify_signature(tarball_path, manifest['signature']):
                log.error("Signature verification FAILED — aborting update")
                sys.exit(1)
            log.info("Signature verified ✓")
        else:
            log.warning("Release is unsigned — proceeding anyway (dev build)")

        backup_current()
        log.info(f"Installing {local_ver} → {remote_ver} ...")
        install_files(tarball_path, remote_ver)

    restart_services()
    log.info(f"Update complete: {local_ver} → {remote_ver}")


if __name__ == '__main__':
    main()
